class IDCard {
    String name;
    int id;
    String department;
    String institution;

    // Constructor
    IDCard(String n, int i, String d, String inst) {
        name = n;
        id = i;
        department = d;
        institution = inst;
    }

    void showID() {
        System.out.println("Name: " + name);
        System.out.println("ID: " + id);
        System.out.println("Department: " + department);
        System.out.println("Institution: " + institution);
    }

    public static void main(String[] args) {
        IDCard student1 = new IDCard("Iftisum Ahmed Ifaz", 253068, "CCE", "IIUC");
        student1.showID();
    }
}
