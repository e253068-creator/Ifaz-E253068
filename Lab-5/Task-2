class LibraryBook {

    String title;
    String author;
    int bookID;

    // Constructor using this keyword
    LibraryBook(String title, String author, int bookID) {
        this.title = title;
        this.author = author;
        this.bookID = bookID;
    }

    // Method to display book information
    void displayBookInfo() {
        System.out.println("Book Title: " + title);
        System.out.println("Author Name: " + author);
        System.out.println("Book ID: " + bookID);
    }
}

public class Main {
    public static void main(String[] args) {

        LibraryBook book1 = new LibraryBook("Java Programming", "James Gosling", 201);
        LibraryBook book2 = new LibraryBook("Database Systems", "Navathe", 202);

        System.out.println("First Book Information:");
        book1.displayBookInfo();

        System.out.println("\nSecond Book Information:");
        book2.displayBookInfo();
    }
}
